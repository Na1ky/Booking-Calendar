# Questo è il file delle variabili d'ambiente di esempio (.env.example)
# Copia questo file rinominandolo in ".env" e inserisci i tuoi valori reali.
# Il file ".env" non verrà tracciato da Git per ragioni di sicurezza.

# Esempio di variabili:
# API_KEY=la_tua_chiave_super_segreta
# DB_CONNECTION=Server=myServerAddress;Database=myDataBase;User Id=myUsername;Password=myPassword;
